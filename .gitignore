# Banking Application .gitignore

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
/var/log/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Java/Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.properties

# .NET
bin/
obj/
publish/
*.user
*.suo

# Node.js/NPM
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
out/
build/
dist/

# Database
*.db
*.sqlite
*.sqlite3

# Docker
.dockerignore

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Test coverage
coverage/
*.cover
*.py,cover
.coverage
.coverage.*
.cache
.pytest_cache/

# Test results and reports
playwright-report/
test-results/

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo

# Build artifacts
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Spring Boot
*.pid
spring-shell.log

# Application specific
application-local.yml
application-local.properties

# proxymock (results and logs — recordings used by CI stay tracked)
**/proxymock/results/
**/*proxymock*.log
**/*.log

# Claude Code
.claude/
thoughts/
gate-out/
